# Database (docker compose up -d gives you this)
DATABASE_URL=postgresql://anyterm:anyterm@localhost:5432/anyterm

# Redis (docker compose up -d gives you this)
REDIS_URL=redis://localhost:6379

# Auth (generate a random secret for production)
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional — omit to hide social login buttons)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Next.js web app
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WebSocket server (separate process, defaults to 3001 if unset)
# WS_PORT=3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
# Internal URL for Next.js API routes to reach the WS server (defaults to http://localhost:WS_PORT)
# WS_SERVER_URL=http://localhost:3001

# Preview iframe origin (separate origin for iframe isolation — prevents
# tunneled pages from accessing the parent's sessionStorage/masterKey).
# In dev, point to the WS server's HTTP origin. In prod, use a separate domain.
NEXT_PUBLIC_PREVIEW_ORIGIN=http://localhost:3001

# Mobile app (optional, set to your Expo dev URL for CORS)
# MOBILE_ORIGIN=exp://192.168.1.x:8081

# CLI server URL (used by anyterm CLI to discover the server)
# ANYTERM_SERVER_URL=http://localhost:3000

# Email (optional — omit for dev, emails logged to console)
# RESEND_API_KEY=re_...
# EMAIL_FROM=anyterm <noreply@anyterm.dev>

# Stripe (optional — omit for self-hosted with full access)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_TEAM_PRICE_ID=price_...

# Admin email (optional — bypasses plan limits, gets "team" tier)
# ADMIN_EMAIL=admin@example.com

# Cron cleanup (optional — protects /api/cron/cleanup endpoint)
# Set a random secret and pass it via: curl -H "Authorization: Bearer $CRON_SECRET" /api/cron/cleanup
# Vercel cron sends this automatically. Omit for self-hosted without auth.
# CRON_SECRET=change-me-to-a-random-secret
