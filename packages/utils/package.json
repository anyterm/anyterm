{
  "name": "@anyterm/utils",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./crypto": "./dist/crypto/index.js",
    "./protocol": "./dist/protocol/index.js",
    "./types": "./dist/types/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/crypto/index.ts src/protocol/index.ts src/types/index.ts --format esm --dts",
    "dev": "tsup src/index.ts src/crypto/index.ts src/protocol/index.ts src/types/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
